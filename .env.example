# Claude API
ANTHROPIC_API_KEY=sk-ant-xxx

# Model tier overrides (optional — process env vars, not loaded from .env by pydantic)
# VIRTUALME_MODEL_FAST=claude-haiku-4-5
# VIRTUALME_MODEL_STANDARD=claude-sonnet-4-6
# VIRTUALME_MODEL_DEEP=claude-opus-4-7

# LINE Bot (optional — only if you wire LINE transport)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Storage
DATABASE_URL=sqlite:///./data/virtualme.db

# Interview settings
SESSION_MAX_MINUTES=25
ENERGY_LOW_THRESHOLD=3
FOLLOW_UP_MAX_DEPTH=3

# Extraction mode — Charter v0.4 PoC runs adaptive extraction over a few
# rounds. adaptive=true stops at MAX_EXTRACTION_ROUNDS (or earlier once
# VOICE/BOUNDARIES each have enough anchors); adaptive=false walks the full
# multi-week question pool instead.
VIRTUALME_ADAPTIVE_EXTRACTION=false
VIRTUALME_MAX_EXTRACTION_ROUNDS=3

# BYOK gate (BW5) — each interviewee provides their own Claude API key.
# When enabled, the interview path never uses ANTHROPIC_API_KEY for LLM calls.
VIRTUALME_BYOK_ENABLED=false
VIRTUALME_BYOK_KEYS_DIR=./data/keys

# Persona auto-export (BW6) — on a sufficient, properly-closed interview, the
# 8 dimension markdowns are exported per-subject and committed to a local-only
# git repo (no remote, never pushed). Incomplete interviews stay staged in DB.
VIRTUALME_PERSONA_AUTO_EXPORT=false
VIRTUALME_PERSONA_EXPORT_DIR=./data/personas

# PPA feature flag (v0.4 experimental)
VIRTUALME_USE_PPA=false
VIRTUALME_PPA_RETRIEVAL_THRESHOLD=0.2
VIRTUALME_PPA_RETRIEVAL_K=5
VIRTUALME_REINJECTION_INTERVAL=20

# Server
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO
